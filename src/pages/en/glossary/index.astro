---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import TopNav from "../../../components/TopNav.astro";
import { getCollection } from "astro:content";

const entries = await getCollection("en_glossary");
entries.sort((a, b) => a.data.title.localeCompare(b.data.title));

const allTags = Array.from(
  new Set(entries.flatMap(e => e.data.tags || []))
).sort();
---

<BaseLayout title="Glossary — English | imoifa.com" lang="en">
  <TopNav lang="en" />

  <div class="card">
    <div class="h1">Glossary</div>
    <p class="muted">Core terms in English.</p>
    <div class="divider"></div>

    <!-- SEARCH -->
    <input
      type="text"
      id="searchInput"
      placeholder="Search terms..."
      style="width:100%; padding:10px; margin-bottom:10px; border:1px solid var(--border); border-radius:8px; background:transparent; color:inherit;"
    />

    <!-- FILTER BAR -->
    <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap; margin-bottom:12px;">
      <div class="muted" id="resultCount"></div>
      <button class="tag" id="clearFilters" type="button" style="display:none;">Clear</button>
    </div>

    <!-- TAG FILTER -->
    <div style="margin-bottom:16px; display:flex; flex-wrap:wrap; gap:8px;">
      {allTags.map(tag => (
        <button class="tag filter-tag" type="button" data-tag={tag}>{tag}</button>
      ))}
    </div>

    <div class="muted" id="noResults" style="display:none; margin: 10px 0 16px;">
      No matching terms.
    </div>

    <div class="grid" id="glossaryGrid">
      {entries.map((e) => (
        <div
          class="card glossary-item"
          data-title={e.data.title.toLowerCase()}
          data-pron={(e.data.pronunciation || "").toLowerCase()}
          data-tags={(e.data.tags || []).join(",").toLowerCase()}
        >
          <div class="h2">{e.data.title}</div>

          {e.data.pronunciation && (
            <div class="muted">
              Pronunciation: {e.data.pronunciation}
            </div>
          )}

          <div style="margin-top: 8px;">
            <a href={`/en/glossary/${e.slug}`}>→ Read</a>
          </div>

          {e.data.tags?.length > 0 && (
            <div style="margin-top: 10px; display:flex; flex-wrap:wrap; gap:8px;">
              {e.data.tags.map((t) => (
                <span class="tag">{t}</span>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  </div>

  <script>
    const searchInput = document.getElementById("searchInput");
    const items = Array.from(document.querySelectorAll(".glossary-item"));
    const tagButtons = Array.from(document.querySelectorAll(".filter-tag"));
    const clearBtn = document.getElementById("clearFilters");
    const countEl = document.getElementById("resultCount");
    const noResults = document.getElementById("noResults");

    let activeTag = null;

    function setActiveButton() {
      tagButtons.forEach(b => b.classList.remove("active"));
      if (!activeTag) return;
      const btn = tagButtons.find(b => b.dataset.tag === activeTag);
      if (btn) btn.classList.add("active");
    }

    function filterItems() {
      const q = (searchInput.value || "").toLowerCase().trim();
      let shown = 0;

      items.forEach(item => {
        const title = item.dataset.title || "";
        const pron = item.dataset.pron || "";
        const tags = item.dataset.tags || "";

        const matchesSearch =
          !q || title.includes(q) || tags.includes(q) || pron.includes(q);

        const matchesTag =
          !activeTag || tags.includes(activeTag.toLowerCase());

        const ok = matchesSearch && matchesTag;
        item.style.display = ok ? "block" : "none";
        if (ok) shown++;
      });

      countEl.textContent = `${shown} result${shown === 1 ? "" : "s"}`;
      noResults.style.display = shown === 0 ? "block" : "none";
      clearBtn.style.display = (activeTag || (searchInput.value || "").trim()) ? "inline-block" : "none";
      setActiveButton();
    }

    searchInput.addEventListener("input", filterItems);

    tagButtons.forEach(btn => {
      btn.addEventListener("click", () => {
        activeTag = (activeTag === btn.dataset.tag) ? null : btn.dataset.tag;
        filterItems();
      });
    });

    clearBtn.addEventListener("click", () => {
      activeTag = null;
      searchInput.value = "";
      filterItems();
    });

    // initial
    filterItems();
  </script>
</BaseLayout>
